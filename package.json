{
  "name": "portfolio-website-jonathan-verdun",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/generate-vfs.mjs",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "docs": "typedoc --out public/docs/api --entryPointStrategy expand src/lib",
    "generate-vfs": "node scripts/generate-vfs.mjs",
    "generate-feed": "node scripts/generate-feed.mjs",
    "check-types": "tsc --noEmit",
    "format": "prettier --write .",
    "e2e": "playwright test",
    "e2e:no-visual": "playwright test --ignore-snapshots --grep-invert @visual",
    "e2e:ui": "playwright test --ui",
    "test:visual": "playwright test e2e/visual.spec.ts",
    "lhci": "lhci autorun",
    "size": "size-limit",
    "prepare": "husky",
    "validate-env": "node scripts/validate-env.mjs",
    "build": "npm run generate-vfs && npm run validate-env && npm test -- --json --outputFile=coverage.json && npm run generate-feed && next build",
    "build:ci": "npm run generate-vfs && node scripts/generate-stub-coverage.mjs && npm run validate-env && npm run generate-feed && next build"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "next": "^16.2.7",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.4",
    "three": "^0.184.0"
  },
  "size-limit": [
    {
      "name": "Static export (gzipped)",
      "path": "out/**/*.html",
      "limit": "1.5 MB"
    },
    {
      "name": "JS bundle (gzipped)",
      "path": "out/_next/static/**/*.js",
      "limit": "800 kB"
    },
    {
      "name": "CSS bundle (gzipped)",
      "path": "out/_next/static/**/*.css",
      "limit": "50 kB"
    }
  ],
  "overrides": {
    "tmp": "^0.2.3",
    "postcss": "^8.5.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.184.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  }
}

# Set automatically by the GitHub Actions configure-pages step.
# Leave empty for local dev (custom domain jonathanverdun.com) or set to
# /repo-name for GitHub project pages (e.g. /jonathan-verdun-portfolio).
BASE_PATH=

# Optional ISO date string for sitemap lastModified (e.g. 2026-04-30).
# Defaults to the current date at build time when unset.
SITE_LAST_MODIFIED=

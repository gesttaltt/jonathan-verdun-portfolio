# ═══════════════════════════════════════════════════════════════
# Environment Variables — Jonathan Verdun Portfolio
# ═══════════════════════════════════════════════════════════════
# These are all the env vars the application reads.
# Prefix reference: NEXT_PUBLIC_ = bundled into the client at build time.
# ═══════════════════════════════════════════════════════════════

# ── Deployment (GitHub Pages) ─────────────────────────────────
# Set automatically by the GitHub Actions configure-pages step.
# Leave empty for local dev (custom domain jonathanverdun.com)
# or set to /repo-name for GitHub project pages.
BASE_PATH=

# Custom site URL override.
# Set by deploy.yml via configure-pages output. Leave unset for
# local dev — siteConfig.ts falls back to jonathanverdun.com or
# a GitHub Pages URL derived from BASE_PATH.
# NEXT_PUBLIC_SITE_URL=https://jonathanverdun.com

# Same as BASE_PATH but prefixed for Next.js public access.
# Set by deploy.yml. Not needed for local dev.
# NEXT_PUBLIC_BASE_PATH=/jonathan-verdun-portfolio

# ── Contact Form (Formspree) ──────────────────────────────────
# Required for the contact form to function.
# Get your Formspree form ID at https://formspree.io
# When unset, the form renders a disabled notice.
# NEXT_PUBLIC_FORMSPREE_ID=xyzabc12

# ── Plausible Analytics ───────────────────────────────────────
# Set the domain to enable the Plausible analytics script.
# Only loaded when this is set. Leave commented for local dev.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=jonathanverdun.com

# ── Sitemap ───────────────────────────────────────────────────
# Optional ISO date string for sitemap lastModified field.
# Example: 2026-04-30 or 2026-04-30T12:00:00.000Z
# Defaults to the current date at build time when unset.
# SITE_LAST_MODIFIED=2026-04-30
